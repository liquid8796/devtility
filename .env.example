# ============================================================
# DevTility — environment variables
# Copy to .env.local for local development. On Vercel these are
# injected automatically by the Marketplace integrations.
# ============================================================

# ---- Upstash Redis (Vercel Marketplace) ----
# Used for: visit analytics counters + exchange-rate history cache.
# Without these the app still runs; analytics falls back to in-memory.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# (legacy Vercel KV naming is also supported)
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

# ---- Vercel Blob (fast object storage) ----
# Used for: sharing code snippets from the online editor.
# Feature is hidden/disabled gracefully when absent.
BLOB_READ_WRITE_TOKEN=

# ---- Code execution provider ----
# Default: Wandbox (free, keyless — OpenJDK 21/22, CPython 3.7–3.14).
# Set EXECUTE_API_URL to a self-hosted Piston to unlock Java 8–25:
# https://github.com/engineer-man/piston
# EXECUTE_API_URL=http://your-piston-host:2000/api/v2

# ---- Analytics bucketing timezone (default Asia/Ho_Chi_Minh) ----
# ANALYTICS_TZ=Asia/Ho_Chi_Minh
